{
  "main": "apps/docs/dist/server/entry.mjs",
  "name": "ui-toolkit",
  "compatibility_date": "2025-12-02",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "no_bundle": true,
  "build": {
    "command": "pnpm run build"
  },
  "rules": [
    { "type": "ESModule", "globs": ["**/*.js", "**/*.mjs"] }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./apps/docs/dist/client"
  },
  "observability": {
    "enabled": true
  }
}
