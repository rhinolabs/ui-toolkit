{
  "main": "apps/docs/dist/server/entry.mjs",
  "name": "ui-toolkit",
  "compatibility_date": "2025-12-02",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./apps/docs/dist/client"
  },
  "observability": {
    "enabled": true
  }
}
