{
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "ui-toolkit",
  "compatibility_date": "2025-12-02",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client"
  },
  "observability": {
    "enabled": true
  }
}
