---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/docs/Header.astro';
import Footer from '../components/docs/Footer.astro';
import { LandingShowcase } from '../components/react/LandingShowcase';
---

<BaseLayout title="UI Toolkit" description="Modern React Components & Hooks by Rhinolabs">
  <div class="relative flex min-h-screen flex-col">
    <Header />

    <main class="flex-1">
      <!-- Hero -->
      <section class="mx-auto max-w-5xl px-4 py-20 text-center md:py-32">
        <a
          href="https://github.com/rhinolabs/ui-toolkit"
          target="_blank"
          rel="noopener noreferrer"
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-muted px-4 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          <svg viewBox="0 0 24 24" class="size-4" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          Open Source on GitHub
        </a>

        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
          <span class="bg-gradient-to-b from-foreground to-muted-foreground bg-clip-text text-transparent">
            The Foundation for your
          </span>
          <br />
          <span class="bg-gradient-to-b from-foreground to-muted-foreground bg-clip-text text-transparent">
            React Applications
          </span>
        </h1>

        <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
          A set of beautifully designed, accessible React components and hooks that you can customize and build on. Start with production-ready code, not boilerplate.
        </p>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a
            href="/introduction"
            class="inline-flex h-11 items-center justify-center rounded-md bg-primary px-8 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
          >
            Get Started
          </a>
          <a
            href="/ui/button"
            class="inline-flex h-11 items-center justify-center rounded-md border border-input bg-background px-8 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
          >
            View Components
          </a>
        </div>
      </section>

      <!-- Live Component Showcase -->
      <section class="border-t border-border bg-muted/30 py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4">
          <LandingShowcase client:only="react" />
        </div>
      </section>

      <!-- Stats -->
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4">
          <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
            <div class="text-center">
              <div class="text-3xl font-bold text-foreground">55+</div>
              <div class="mt-1 text-sm text-muted-foreground">UI Components</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-foreground">37+</div>
              <div class="mt-1 text-sm text-muted-foreground">React Hooks</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-foreground">100%</div>
              <div class="mt-1 text-sm text-muted-foreground">TypeScript</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-foreground">MIT</div>
              <div class="mt-1 text-sm text-muted-foreground">Licensed</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Features -->
      <section class="border-t border-border py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4">
          <h2 class="text-center text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
            Built for modern development
          </h2>
          <p class="mx-auto mt-3 max-w-2xl text-center text-muted-foreground">
            Everything you need to build beautiful, accessible React applications.
          </p>

          <div class="mt-12 grid gap-6 md:grid-cols-3">
            <div class="rounded-lg border border-border bg-card p-6">
              <div class="flex size-10 items-center justify-center rounded-md bg-primary/10 text-primary">
                <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </div>
              <h3 class="mt-4 font-semibold text-foreground">Accessible</h3>
              <p class="mt-2 text-sm text-muted-foreground">
                Built on Radix UI with WAI-ARIA compliant components. Keyboard navigation and screen reader support out of the box.
              </p>
            </div>

            <div class="rounded-lg border border-border bg-card p-6">
              <div class="flex size-10 items-center justify-center rounded-md bg-primary/10 text-primary">
                <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="7" height="7"/>
                  <rect x="14" y="3" width="7" height="7"/>
                  <rect x="14" y="14" width="7" height="7"/>
                  <rect x="3" y="14" width="7" height="7"/>
                </svg>
              </div>
              <h3 class="mt-4 font-semibold text-foreground">Customizable</h3>
              <p class="mt-2 text-sm text-muted-foreground">
                Styled with Tailwind CSS and design tokens. Easily adapt the look and feel to match your brand.
              </p>
            </div>

            <div class="rounded-lg border border-border bg-card p-6">
              <div class="flex size-10 items-center justify-center rounded-md bg-primary/10 text-primary">
                <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="16 18 22 12 16 6"/>
                  <polyline points="8 6 2 12 8 18"/>
                </svg>
              </div>
              <h3 class="mt-4 font-semibold text-foreground">Developer Experience</h3>
              <p class="mt-2 text-sm text-muted-foreground">
                Full TypeScript support, tree-shakeable exports, and zero-config setup. Just install and start building.
              </p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
