{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!node_modules/**", "!dist/**", "!coverage/**", "!.next/**", "!out/**", "!_pagefind/**", "!**/*.css"]
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noAssignInExpressions": "off",
				"noExplicitAny": "off",
				"noDocumentCookie": "off",
				"noArrayIndexKey": "off",
				"noShadowRestrictedNames": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": "off"
			},
			"a11y": {
				"useSemanticElements": "off",
				"useAriaPropsSupportedByRole": "off",
				"useKeyWithClickEvents": "off",
				"useFocusableInteractive": "off",
				"noRedundantRoles": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	}
}
